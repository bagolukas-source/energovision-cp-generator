# === Supabase (Energovision CRM databáza) ===
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.xxxxx.supabase.co:5432/postgres

# === Vendor API credentials ===
# Tieto sa primárne ukladajú do tabuľky inverter_vendor_credentials,
# tu sú len fallback alebo pre lokálny test.

VENDOR_HUAWEI_ENABLED=true
HUAWEI_USERNAME=energovision_installer
HUAWEI_PASS=...
HUAWEI_API_BASE=https://intl.fusionsolar.huawei.com  # alebo region-specific

VENDOR_SOLINTEG_ENABLED=true
SOLINTEG_APP_KEY=...
SOLINTEG_APP_SECRET=...
SOLINTEG_USERNAME=energovision_installer
SOLINTEG_API_BASE=https://api.solinteg-cloud.com

VENDOR_GOODWE_ENABLED=true
GOODWE_USERNAME=energovision_installer
GOODWE_PASS=...
GOODWE_API_BASE=https://www.semsportal.com

VENDOR_FRONIUS_ENABLED=true
FRONIUS_CLIENT_ID=...
FRONIUS_CLIENT_SECRET=...
FRONIUS_ACCESS_KEY_ID=...
FRONIUS_ACCESS_KEY_VALUE=...
FRONIUS_API_BASE=https://api.solarweb.com

VENDOR_SUNGROW_ENABLED=true
SUNGROW_APP_KEY=...
SUNGROW_USERNAME=energovision_installer
SUNGROW_PASS=...
SUNGROW_API_BASE=https://gateway.isolarcloud.eu

# === Dispečing config ===
DISPATCH_READ_ONLY=false         # ak true, žiaden send_command nepôjde von
DISPATCH_PAUSE_SECRET=...        # pre /webhook/dispatch-pause
ZERO_EXPORT_TOLERANCE_KWH=0.05   # per 15min window
ZERO_EXPORT_CONSECUTIVE_WINDOWS=2

# === Notifikácie ===
SLACK_BOT_TOKEN=xoxb-...
SLACK_DISPATCH_CHANNEL=#dispatch-alarms
SENDGRID_API_KEY=SG...
NOTIFICATION_FROM_EMAIL=dispecing@energovision.sk
TWILIO_ACCOUNT_SID=AC...        # voliteľne pre SMS
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_PHONE=+421...

# === LLM (pre AI co-pilot a generatívne reporty) ===
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6
